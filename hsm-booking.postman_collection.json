              "mode": "raw",
              "raw": "{\n  \"premise\": {{premiseId}},\n  \"slot\": {{slotId}},\n  \"from_date\": \"2026-04-20\",\n  \"to_date\": \"2026-04-21\",\n  \"total_days\": 2,\n  \"full_name\": \"Rahul Patil\",\n  \"address\": \"Solapur, Maharashtra\",\n  \"mobile\": \"9876543210\",\n  \"alt_mobile\": \"9876543211\",\n  \"email\": \"rahul.patil@example.com\",\n  \"function_name\": \"Family Wedding\",\n  \"function_type\": \"marriage\",\n  \"expected_guests\": 300,\n  \"id_proof_type\": \"aadhaar\",\n  \"id_proof_number\": \"123412341234\",\n  \"bank_name\": \"State Bank of India\",\n  \"account_holder\": \"Rahul Patil\",\n  \"account_number\": \"123456789012\",\n  \"ifsc_code\": \"SBIN0001234\",\n  \"branch_name\": \"Solapur Main\",\n  \"micr_code\": \"413002001\",\n  \"base_rent\": \"50000.00\",\n  \"holiday_charges\": \"0.00\",\n  \"security_deposit\": \"10000.00\",\n  \"cgst\": \"4500.00\",\n  \"sgst\": \"4500.00\",\n  \"total_payable\": \"69000.00\",\n  \"payment_mode\": \"bank_transfer\"\n}"
            },
            "url": "{{baseUrl}}/api/bookings/"
          }
        },
